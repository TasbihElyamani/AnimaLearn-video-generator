# ─── AnimaLearn — Environment Variables ───

# Groq API — LLM (free: https://console.groq.com/ — no credit card needed)
GROQ_API_KEY=your_groq_api_key_here

# Embeddings: uses local sentence-transformers (no API key needed)

# Qdrant (free cloud: https://cloud.qdrant.io/ or self-host)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=animalearn_references

# AI Animation — Runway API (free: 125 credits at https://dev.runwayml.com/)
RUNWAY_API_KEY=

# AI Avatar — D-ID API (free trial: https://studio.d-id.com/)
DID_API_KEY=

# Mock mode: "true" = deterministic stubs, no API calls needed
MOCK_MODE=true

LOG_LEVEL=INFO
LOG_FILE=outputs/trace_logs.jsonl
